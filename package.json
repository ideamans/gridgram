{
  "name": "gridgram",
  "version": "0.1.0",
  "description": "Grid-based diagram rendering library (SVG / PNG) built on React SSR",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "gg": "bun run src/cli/gg.ts",
    "compile": "bun build --compile --minify --sourcemap=external --external sharp --external '@img/*' src/cli/gg.ts --outfile gg",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "sync-tabler": "bun scripts/sync-tabler-icons.ts",
    "sync-licenses": "bun scripts/sync-licenses.ts",
    "docs:examples": "bun scripts/build-docs-examples.ts",
    "docs:logo": "bun scripts/pick-monthly-logo.ts",
    "docs:logos:export": "bun scripts/export-logos.ts",
    "docs:dev": "bun run docs:examples && bun run docs:logo && vitepress dev docs",
    "docs:build": "bun run docs:examples && bun run docs:logo && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@tabler/icons": "^3.41.1",
    "json5": "^2.2.3",
    "preact": "^10.29.1",
    "preact-render-to-string": "^6.6.7",
    "sharp": "^0.33.2",
    "vitepress-daisyui-theme": "^0.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vitepress": "^1.6.4",
    "vue": "^3.5.32"
  }
}

{
  "name": "gridgram",
  "version": "0.1.0",
  "description": "Grid-based diagram rendering library — authored as a DiagramDef or a .gg file, rendered to SVG via Preact SSR.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_LICENSES.md"
  ],
  "sideEffects": false,
  "keywords": [
    "diagram",
    "svg",
    "preact",
    "ssr",
    "grid",
    "visualization",
    "dsl",
    "architecture-diagram"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ideamans/gridgram.git"
  },
  "bugs": {
    "url": "https://github.com/ideamans/gridgram/issues"
  },
  "homepage": "https://github.com/ideamans/gridgram#readme",
  "license": "MIT",
  "scripts": {
    "gg": "bun run src/cli/gg.ts",
    "compile": "bun build --compile --minify --sourcemap=external --external sharp --external '@img/*' src/cli/gg.ts --outfile gg",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "sync-tabler": "bun scripts/sync-tabler-icons.ts",
    "sync-licenses": "bun scripts/sync-licenses.ts",
    "clean:dist": "rm -rf dist",
    "build:lib": "bun run clean:dist && bun run sync-tabler && tsc -p tsconfig.build.json && mkdir -p dist/data && cp src/data/tabler-outline.json src/data/tabler-filled.json dist/data/",
    "prepublishOnly": "bun run build:lib",
    "docs:examples": "bun scripts/build-docs-examples.ts",
    "docs:logo": "bun scripts/pick-monthly-logo.ts",
    "docs:logos:export": "bun scripts/export-logos.ts",
    "docs:dev": "bun run docs:examples && bun run docs:logo && vitepress dev docs",
    "docs:build": "bun run docs:examples && bun run docs:logo && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "json5": "^2.2.3",
    "preact": "^10.29.1",
    "preact-render-to-string": "^6.6.7"
  },
  "devDependencies": {
    "@tabler/icons": "^3.41.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest",
    "daisyui": "^5.5.19",
    "sharp": "^0.33.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vitepress": "^1.6.4",
    "vitepress-daisyui-theme": "^0.2.0",
    "vue": "^3.5.32"
  }
}

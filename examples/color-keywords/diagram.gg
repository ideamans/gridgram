# Theme keywords and alpha syntax for node colors

doc {
  cols: 4,
  theme: { primary: '#1e3a5f', secondary: '#3b5a80', accent: '#e8792f' },
}

icon @A1 tabler/circle "primary"     color=primary
icon @B1 tabler/circle "accent"      color=accent
icon @C1 tabler/circle "accent/60"   color=accent/60
icon @D1 tabler/circle "#8b5cf6"     color=#8b5cf6
